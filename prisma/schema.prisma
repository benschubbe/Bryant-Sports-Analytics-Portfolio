// Bryant University Club Platform — Prisma Schema
// Multi-club campus portal system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Club Models ─────────────────────────────────────────────────────────────

model Club {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  domain      String?
  logoUrl     String?  @map("logo_url")
  bannerUrl   String?  @map("banner_url")
  color       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  memberships   ClubMembership[]
  invites       ClubInvite[]
  projects      Project[]
  posts         Post[]
  channels      Channel[]
  events        Event[]
  jobs          Job[]
  challenges    Challenge[]
  learningPaths LearningPath[]
  tutorials     Tutorial[]
  mentorMatches MentorMatch[]
  weeklyDigests WeeklyDigest[]

  @@index([slug])
  @@map("clubs")
}

model ClubMembership {
  id       String   @id @default(cuid())
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  clubId String @map("club_id")
  club   Club   @relation(fields: [clubId], references: [id])

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
  @@map("club_memberships")
}

model ClubInvite {
  id        String    @id @default(cuid())
  email     String
  role      String    @default("MEMBER")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Relations
  clubId String @map("club_id")
  club   Club   @relation(fields: [clubId], references: [id])

  @@index([clubId])
  @@index([token])
  @@map("club_invites")
}

// ─── User Model ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?  @map("password_hash")
  image        String?
  bio          String?
  classYear    String?  @map("class_year")
  concentration String?
  headline     String?
  linkedinUrl  String?  @map("linkedin_url")
  githubUrl    String?  @map("github_url")
  personalUrl  String?  @map("personal_url")
  role         String   @default("STUDENT")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  memberships           ClubMembership[]
  projects              Project[]
  posts                 Post[]
  comments              Comment[]
  reviewsGiven          Review[]              @relation("ReviewerRelation")
  reviewsReceived       Review[]              @relation("ReviewAuthorRelation")
  reactions             Reaction[]
  messagesSent          Message[]             @relation("MessageSender")
  messagesReceived      Message[]             @relation("MessageReceiver")
  applications          Application[]
  certifications        Certification[]
  challengeSubmissions  ChallengeSubmission[]
  eventRsvps            EventRsvp[]
  mentorOf              MentorMatch[]         @relation("MentorRelation")
  menteeOf              MentorMatch[]         @relation("MenteeRelation")
  tutorials             Tutorial[]

  @@map("users")
}

// ─── Content Models ──────────────────────────────────────────────────────────

model Project {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  abstract      String?
  content       String?
  methodology   String?
  sport         String   @default("[]")
  technique     String   @default("[]")
  tools         String   @default("[]")
  domain        String   @default("[]")
  visibility    String   @default("PUBLIC")
  mediaUrls     String   @default("[]") @map("media_urls")
  githubUrl     String?  @map("github_url")
  tableauUrl    String?  @map("tableau_url")
  videoUrl      String?  @map("video_url")
  views         Int      @default(0)
  openForReview Boolean  @default(false) @map("open_for_review")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  authorId String  @map("author_id")
  author   User    @relation(fields: [authorId], references: [id])
  clubId   String? @map("club_id")
  club     Club?   @relation(fields: [clubId], references: [id])
  comments Comment[]
  reviews  Review[]
  tags     Tag[]

  challengeSubmissions ChallengeSubmission[]

  @@index([slug])
  @@index([authorId])
  @@index([clubId])
  @@map("projects")
}

model Post {
  id        String   @id @default(cuid())
  content   String
  mediaUrls String   @default("[]") @map("media_urls")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  authorId  String    @map("author_id")
  author    User      @relation(fields: [authorId], references: [id])
  channelId String?   @map("channel_id")
  channel   Channel?  @relation(fields: [channelId], references: [id])
  clubId    String?   @map("club_id")
  club      Club?     @relation(fields: [clubId], references: [id])
  comments  Comment[]
  reactions Reaction[]

  @@index([authorId])
  @@index([channelId])
  @@index([clubId])
  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id])
  postId    String?  @map("post_id")
  post      Post?    @relation(fields: [postId], references: [id])
  parentId  String?  @map("parent_id")
  parent    Comment? @relation("CommentThread", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentThread")
  reactions Reaction[]

  @@index([authorId])
  @@index([projectId])
  @@index([postId])
  @@index([parentId])
  @@map("comments")
}

model Reaction {
  id        String   @id @default(cuid())
  type      String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  postId    String?  @map("post_id")
  post      Post?    @relation(fields: [postId], references: [id])
  commentId String?  @map("comment_id")
  comment   Comment? @relation(fields: [commentId], references: [id])

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([userId])
  @@map("reactions")
}

model Channel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sport       String?
  type        String   @default("GENERAL")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  clubId String? @map("club_id")
  club   Club?   @relation(fields: [clubId], references: [id])
  posts  Post[]

  @@index([name])
  @@index([clubId])
  @@map("channels")
}

model Review {
  id                 String   @id @default(cuid())
  methodologyScore   Int      @map("methodology_score")
  visualizationScore Int      @map("visualization_score")
  writingScore       Int      @map("writing_score")
  codeQualityScore   Int      @map("code_quality_score")
  rigorScore         Int      @map("rigor_score")
  feedback           String
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  reviewerId String  @map("reviewer_id")
  reviewer   User    @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  projectId  String  @map("project_id")
  project    Project @relation(fields: [projectId], references: [id])
  authorId   String  @map("author_id")
  author     User    @relation("ReviewAuthorRelation", fields: [authorId], references: [id])

  @@index([reviewerId])
  @@index([projectId])
  @@index([authorId])
  @@map("reviews")
}

model Job {
  id               String    @id @default(cuid())
  title            String
  company          String
  description      String
  sport            String?
  roleType         String    @map("role_type")
  location         String?
  experienceLevel  String    @map("experience_level")
  remote           Boolean   @default(false)
  url              String?
  postedById       String?   @map("posted_by_id")
  bryantConnection Boolean   @default(false) @map("bryant_connection")
  createdAt        DateTime  @default(now()) @map("created_at")
  expiresAt        DateTime? @map("expires_at")

  // Relations
  clubId       String?       @map("club_id")
  club         Club?         @relation(fields: [clubId], references: [id])
  applications Application[]

  @@index([roleType])
  @@index([experienceLevel])
  @@index([clubId])
  @@map("jobs")
}

model Application {
  id           String    @id @default(cuid())
  status       String    @default("INTERESTED")
  notes        String?
  contactInfo  String?   @map("contact_info")
  followUpDate DateTime? @map("follow_up_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  jobId  String @map("job_id")
  job    Job    @relation(fields: [jobId], references: [id])

  @@index([userId])
  @@index([jobId])
  @@map("applications")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  senderId   String @map("sender_id")
  sender     User   @relation("MessageSender", fields: [senderId], references: [id])
  receiverId String @map("receiver_id")
  receiver   User   @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String
  datasetUrl  String?  @map("dataset_url")
  sport       String?
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  clubId      String?               @map("club_id")
  club        Club?                 @relation(fields: [clubId], references: [id])
  submissions ChallengeSubmission[]

  @@index([clubId])
  @@map("challenges")
}

model ChallengeSubmission {
  id        String   @id @default(cuid())
  content   String
  votes     Int      @default(0)
  winner    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  challengeId String    @map("challenge_id")
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  projectId   String?   @map("project_id")
  project     Project?  @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([challengeId])
  @@map("challenge_submissions")
}

model LearningPath {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  sport       String?
  steps       String   @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  clubId String? @map("club_id")
  club   Club?   @relation(fields: [clubId], references: [id])

  @@index([slug])
  @@index([clubId])
  @@map("learning_paths")
}

model Tutorial {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  tool      String?
  category  String?
  staffPick Boolean  @default(false) @map("staff_pick")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id])
  clubId   String? @map("club_id")
  club     Club?   @relation(fields: [clubId], references: [id])

  @@index([slug])
  @@index([authorId])
  @@index([clubId])
  @@map("tutorials")
}

model Certification {
  id              String   @id @default(cuid())
  name            String
  provider        String
  completedAt     DateTime @map("completed_at")
  verificationUrl String?  @map("verification_url")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("certifications")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String
  location    String?
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  clubId String? @map("club_id")
  club   Club?   @relation(fields: [clubId], references: [id])
  rsvps  EventRsvp[]

  @@index([clubId])
  @@map("events")
}

model EventRsvp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id])
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("event_rsvps")
}

model MentorMatch {
  id        String   @id @default(cuid())
  status    String   @default("PENDING")
  cadence   String   @default("AD_HOC")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  mentorId String @map("mentor_id")
  mentor   User   @relation("MentorRelation", fields: [mentorId], references: [id])
  menteeId String @map("mentee_id")
  mentee   User   @relation("MenteeRelation", fields: [menteeId], references: [id])
  clubId   String? @map("club_id")
  club     Club?   @relation(fields: [clubId], references: [id])

  @@index([mentorId])
  @@index([menteeId])
  @@index([clubId])
  @@map("mentor_matches")
}

model WeeklyDigest {
  id        String   @id @default(cuid())
  content   String
  weekOf    DateTime @map("week_of")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  clubId String? @map("club_id")
  club   Club?   @relation(fields: [clubId], references: [id])

  @@index([clubId])
  @@map("weekly_digests")
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  projects Project[]

  @@map("tags")
}
